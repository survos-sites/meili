{# templates/js/product.html.twig (Twig-JS compatible) #}
{% set cfg = {
    pk:        _config.primaryKey | default('id'),
    maxLen:    (_config.maxLen is defined) ? _config.maxLen : 120,
    maxList:   (_config.maxList is defined) ? _config.maxList : 6,
    prettyJson: (_config.prettyJson is defined) ? _config.prettyJson : true
} %}

{% set pkVal = attribute(hit, cfg.pk) is defined ? attribute(hit, cfg.pk) : (hit.id ?? null) %}
{% set isDetails = (globals.details is defined and globals.details) %}

{# pick first image-ish URL (jpg/jpeg, querystring okay) #}
{% set imageUrl = hit.thumbnail %}
{% for k, v in hit %}
    {% if imageUrl is null and (v is not iterable) and (v is not same as(null)) %}
        {% set s = (v)|lower %}
        {% if ('http://' in s or 'https://' in s) and ('.jpg' in s or '.jpeg' in s) %}
            {% set imageUrl = v %}
        {% endif %}
    {% endif %}
{% endfor %}

{% if isDetails %}
{# ── Detail panel view (right-hand panel, full product) ── #}
<div class="p-3">
    {% if imageUrl %}
        <img
            src="{{ imageUrl }}"
            alt="{{ hit.title|default('Product image') }}"
            class="img-fluid d-block mx-auto rounded mb-3"
            loading="lazy" decoding="async"
            style="max-height:300px; width:auto; height:auto; max-width:100%;"
        >
    {% endif %}

    {% if hit.title ?? false %}
        <h4 class="mb-1" style="word-break:break-word;">{{ hit.title }}</h4>
    {% endif %}

    {% if hit.price ?? false %}
        <div class="fs-5 fw-bold text-success mb-2">${{ hit.price }}</div>
    {% endif %}

    {% if hit.brand ?? false %}
        <div class="text-muted small mb-2">Brand: {{ hit.brand }}</div>
    {% endif %}

    {% if hit.category ?? false %}
        <div class="mb-2">
            <span class="badge bg-secondary">{{ hit.category }}</span>
        </div>
    {% endif %}

    {% if hit.description ?? false %}
        <div class="mt-2" style="line-height:1.6;">{{ hit.description }}</div>
    {% endif %}

    {% if hit.url ?? false %}
        <div class="mt-3">
            <a href="{{ hit.url }}" target="_blank" rel="noreferrer" class="btn btn-sm btn-outline-primary">
                Open product page
            </a>
        </div>
    {% endif %}
</div>

{% else %}
{# ── Card view (search results grid) ── #}
<div class="card h-100 shadow-sm border-0">

    <div class="card-body p-3">
        {% if imageUrl %}
            <img
                src="{{ imageUrl }}"
                alt="{{ hit.title|default('Image') }}"
                class="img-fluid d-block mx-auto rounded-top"
                loading="lazy" decoding="async"
                style="max-height:160px; width:auto; height:auto; max-width:100%;"
            >
        {% endif %}

        {% if hit.title ?? false %}
            <h5 class="card-title mb-2 text-wrap" style="white-space:normal; word-break:break-word;">
                {{ hit.title }}
            </h5>
        {% endif %}

        {% if hit.price ?? false %}
            <div class="fw-bold text-success mb-1">${{ hit.price }}</div>
        {% endif %}

        {% if hit.description ?? false %}
            <div class="card-text text-muted small" style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical;">
                {{ hit.description }}
            </div>
        {% endif %}
    </div>

    <div class="card-footer bg-transparent border-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
        {# JSON debug pop-up — keep as-is #}
        <button
            {{ stimulus_action(globals._sc_modal, 'modal') }}
            data-hit-id="{{ pkVal }}"
            class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1"
            title="View JSON details">
            {{ ux_icon('json')|raw }}
        </button>

        {# Show details in the right-hand panel (chat) or offcanvas (insta) #}
        <button
            class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1"
            data-show-detail="1"
            data-hit-id="{{ pkVal }}"
            title="Show details">
            Show details
        </button>

        {% if hit.url ?? false %}
            <a href="{{ hit.url }}" target="_blank" rel="noreferrer" class="btn btn-sm btn-outline-secondary">
                Open
            </a>
        {% endif %}
    </div>
</div>
{% endif %}
