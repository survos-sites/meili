{
    "controllers": {
        "@survos/api-grid-bundle": {
            "api_grid": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "datatables.net-columncontrol-bs5/css/columnControl.bootstrap5.css": true,
                    "datatables.net-bs5/css/dataTables.bootstrap5.css": true,
                    "datatables.net-buttons-bs5/css/buttons.bootstrap5.css": true,
                    "datatables.net-responsive-bs5/css/responsive.bootstrap5.css": true,
                    "datatables.net-scroller-bs5/css/scroller.bootstrap5.css": true,
                    "datatables.net-searchbuilder-bs5/css/searchBuilder.bootstrap5.css": true,
                    "datatables.net-select-bs5/css/select.bootstrap5.css": true
                }
            }
        },
        "@survos/html-prettify-bundle": {
            "prettify": {
                "enabled": true,
                "fetch": "eager"
            }
        },
        "@survos/js-twig-bundle": {
            "dexie": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": []
            },
            "js_twig": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            }
        },
        "@survos/meili-bundle": {
            "insta": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "instantsearch.css/themes/algolia.min.css": true,
                    "pretty-print-json/dist/css/pretty-print-json.min.css": true
                }
            },
            "json": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            },
            "chat": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "@survos/meili/styles/chat.css": true
                }
            }
        },
        "@survos/simple-datatables-bundle": {
            "table": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "@survos/simple-datatables/style.css": true
                }
            }
        },
        "@survos/state-bundle": {
            "workflow": {
                "enabled": true,
                "fetch": "eager"
            }
        },
        "@survos/tabler-bundle": {
            "accordion": {
                "enabled": true,
                "fetch": "lazy"
            },
            "search": {
                "enabled": true,
                "fetch": "lazy"
            }
        },
        "@symfony/ux-chartjs": {
            "chart": {
                "enabled": true,
                "fetch": "eager"
            }
        }
    },
    "entrypoints": []
}
